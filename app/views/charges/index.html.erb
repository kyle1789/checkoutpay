<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@400;500&display=swap');

  .charges-wrapper { font-family: 'DM Sans', sans-serif; }

  .charge-row { transition: background 0.15s ease; }
  .charge-row:hover { background: #f8f7ff; }

  .btn-process {
    position: relative;
    overflow: hidden;
  }
  .btn-process::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.15);
    opacity: 0;
    transition: opacity 0.2s;
  }
  .btn-process:hover::after { opacity: 1; }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    display: inline-block;
    margin-right: 6px;
  }

  .mono { font-family: 'DM Mono', monospace; }

  .fade-in {
    animation: fadeUp 0.3s ease both;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .stat-card {
    background: white;
    border: 1px solid #ede9fe;
    border-radius: 14px;
    padding: 20px 24px;
    transition: box-shadow 0.2s;
  }
  .stat-card:hover { box-shadow: 0 4px 20px rgba(109,40,217,0.08); }
</style>

<div class="charges-wrapper min-h-screen bg-[#f5f4fb] px-6 py-10">
  <div class="max-w-6xl mx-auto">

    <%# ── Header ─────────────────────────────────────── %>
    <div class="flex items-start justify-between mb-8 fade-in">
      <div>
        <p class="text-xs font-semibold tracking-widest text-violet-500 uppercase mb-1">Financeiro</p>
        <h1 class="text-3xl font-semibold text-gray-900 tracking-tight">Cobranças</h1>
      </div>

      <%= link_to new_charge_path,
            class: "inline-flex items-center gap-2 bg-violet-600 hover:bg-violet-700 active:bg-violet-800 text-white px-5 py-2.5 rounded-xl text-sm font-semibold shadow-sm shadow-violet-200 transition-all duration-150" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
        </svg>
        Nova cobrança
      <% end %>
    </div>

    <%# ── Stats ──────────────────────────────────────── %>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8 fade-in" style="animation-delay:0.05s">
      <div class="stat-card">
        <p class="text-xs text-gray-400 font-medium mb-1">Total</p>
        <p class="text-2xl font-semibold text-gray-900 mono"><%= @charges.count %></p>
      </div>
      <div class="stat-card">
        <p class="text-xs text-gray-400 font-medium mb-1">Sucesso</p>
        <p class="text-2xl font-semibold text-emerald-600 mono"><%= @charges.count(&:succeeded?) %></p>
      </div>
      <div class="stat-card">
        <p class="text-xs text-gray-400 font-medium mb-1">Processando</p>
        <p class="text-2xl font-semibold text-amber-500 mono"><%= @charges.count(&:processing?) %></p>
      </div>
      <div class="stat-card">
        <p class="text-xs text-gray-400 font-medium mb-1">Falhas</p>
        <p class="text-2xl font-semibold text-rose-500 mono"><%= @charges.count(&:failed?) %></p>
      </div>
    </div>

    <%# ── Table ──────────────────────────────────────── %>
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden fade-in" style="animation-delay:0.1s">

      <% if @charges.empty? %>
        <div class="flex flex-col items-center justify-center py-20 gap-4">
          <div class="w-14 h-14 rounded-2xl bg-violet-50 flex items-center justify-center">
            <svg class="w-7 h-7 text-violet-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/>
            </svg>
          </div>
          <div class="text-center">
            <p class="text-gray-800 font-semibold">Nenhuma cobrança ainda</p>
            <p class="text-gray-400 text-sm mt-1">Crie a primeira cobrança para começar.</p>
          </div>
          <%= link_to "Criar cobrança", new_charge_path,
                class: "mt-2 inline-flex items-center gap-1.5 text-sm font-semibold text-violet-600 hover:text-violet-700 transition" %>
        </div>

      <% else %>
        <table class="w-full">
          <thead>
            <tr class="border-b border-gray-100 bg-gray-50/60">
              <th class="px-6 py-3.5 text-left text-[11px] font-semibold tracking-wider text-gray-400 uppercase">ID</th>
              <th class="px-6 py-3.5 text-left text-[11px] font-semibold tracking-wider text-gray-400 uppercase">Status</th>
              <th class="px-6 py-3.5 text-left text-[11px] font-semibold tracking-wider text-gray-400 uppercase">Valor</th>
              <th class="px-6 py-3.5 text-left text-[11px] font-semibold tracking-wider text-gray-400 uppercase">Moeda</th>
              <th class="px-6 py-3.5 text-left text-[11px] font-semibold tracking-wider text-gray-400 uppercase">Descrição</th>
              <th class="px-6 py-3.5 text-right text-[11px] font-semibold tracking-wider text-gray-400 uppercase">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <% @charges.each do |charge| %>
              <tr class="charge-row">

                <%# ID %>
                <td class="px-6 py-4">
                  <span class="mono text-xs font-medium text-gray-400">#<%= charge.id %></span>
                </td>

                <%# Status badge %>
                <td class="px-6 py-4">
                  <% if charge.succeeded? %>
                    <span class="inline-flex items-center rounded-lg bg-emerald-50 px-2.5 py-1 text-xs font-semibold text-emerald-700 ring-1 ring-emerald-100">
                      <span class="status-dot bg-emerald-500"></span> Sucesso
                    </span>
                  <% elsif charge.processing? %>
                    <span class="inline-flex items-center rounded-lg bg-amber-50 px-2.5 py-1 text-xs font-semibold text-amber-700 ring-1 ring-amber-100">
                      <span class="status-dot bg-amber-400"></span> Processando
                    </span>
                  <% elsif charge.failed? %>
                    <span class="inline-flex items-center rounded-lg bg-rose-50 px-2.5 py-1 text-xs font-semibold text-rose-700 ring-1 ring-rose-100">
                      <span class="status-dot bg-rose-500"></span> Falhou
                    </span>
                  <% else %>
                    <span class="inline-flex items-center rounded-lg bg-gray-100 px-2.5 py-1 text-xs font-semibold text-gray-500 ring-1 ring-gray-200">
                      <span class="status-dot bg-gray-400"></span> Pendente
                    </span>
                  <% end %>
                </td>

                <%# Valor %>
                <td class="px-6 py-4">
                  <span class="mono text-sm font-semibold text-gray-900"><%= charge.amount_brl %></span>
                </td>

                <%# Moeda %>
                <td class="px-6 py-4">
                  <span class="mono text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-md font-medium">
                    <%= charge.currency.upcase %>
                  </span>
                </td>

                <%# Descrição %>
                <td class="px-6 py-4 max-w-[220px]">
                  <% if charge.description.present? %>
                    <p class="text-sm text-gray-600 truncate" title="<%= charge.description %>">
                      <%= charge.description %>
                    </p>
                  <% else %>
                    <span class="text-gray-300 text-sm">—</span>
                  <% end %>
                </td>

                <%# Ações %>
                <td class="px-6 py-4">
                  <div class="flex items-center justify-end gap-2">
                    <%= link_to charge_path(charge),
                          class: "text-sm font-medium text-violet-600 hover:text-violet-800 transition px-3 py-1.5 rounded-lg hover:bg-violet-50" do %>
                      Ver
                    <% end %>

                    <% unless charge.succeeded? || charge.processing? %>
                      <%= button_to process_charge_charge_path(charge),
                            method: :post,
                            form_class: "inline",
                            class: "btn-process text-sm font-semibold bg-violet-600 hover:bg-violet-700 text-white px-3 py-1.5 rounded-lg transition shadow-sm shadow-violet-100" do %>
                        Processar
                      <% end %>
                    <% end %>
                  </div>
                </td>

              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>

    </div>
    <%# ── Footer count ──────────────────────────────── %>
    <% if @charges.any? %>
      <p class="text-center text-xs text-gray-400 mt-4">
        <%= @charges.count %> cobrança<%= @charges.count == 1 ? "" : "s" %> no total
      </p>
    <% end %>

  </div>
</div>